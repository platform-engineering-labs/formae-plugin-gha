/// GitHub Actions organization secret.
module org.orgsecret

import "@formae/formae.pkl"
import "../gha.pkl"

/// A GitHub Actions organization secret.
@gha.ResourceHint {
    type = "GHA::Org::Secret"
    identifier = "name"
}
class Secret extends formae.Resource {
    fixed hidden type: String = "GHA::Org::Secret"

    /// Secret name.
    @gha.FieldHint { createOnly = true }
    name: String

    /// Secret value (plaintext). Encrypted by the plugin.
    @gha.FieldHint { writeOnly = true }
    value: String

    /// SHA-256 hash of the plaintext value for drift detection.
    @gha.FieldHint {}
    valueHash: String?

    /// Visibility: which repos can access this secret.
    @gha.FieldHint {}
    visibility: gha.Visibility

    /// Repository IDs when visibility is "selected".
    @gha.FieldHint {}
    selectedRepositoryIds: Listing<Int>?
}
