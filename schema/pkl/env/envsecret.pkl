/// GitHub Actions environment secret.
module env.envsecret

import "@formae/formae.pkl"
import "../gha.pkl"

/// A GitHub Actions environment secret.
@gha.ResourceHint {
    type = "GHA::Environment::Secret"
    identifier = "name"
    parent = "GHA::Repo::Environment"
    listParam = new formae.ListProperty {
        parentProperty = "name"
        listParameter = "environment"
    }
}
class Secret extends formae.Resource {
    fixed hidden type: String = "GHA::Environment::Secret"

    /// The environment this secret belongs to. Use env.res.name for dependency ordering.
    @gha.FieldHint { createOnly = true }
    environment: String|formae.Resolvable

    /// Secret name.
    @gha.FieldHint { createOnly = true }
    name: String

    /// Secret value (plaintext). Encrypted by the plugin.
    @gha.FieldHint { writeOnly = true }
    value: String

    /// SHA-256 hash of the plaintext value for drift detection.
    @gha.FieldHint {}
    valueHash: String?
}
