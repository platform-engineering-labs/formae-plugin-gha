/// GitHub Actions repository secret.
module repo.reposecret

import "@formae/formae.pkl"
import "../gha.pkl"

/// A GitHub Actions repository secret.
@gha.ResourceHint {
    type = "GHA::Repo::Secret"
    identifier = "name"
}
class Secret extends formae.Resource {
    fixed hidden type: String = "GHA::Repo::Secret"

    /// Secret name. Must be uppercase alphanumeric + underscore.
    /// Cannot start with GITHUB_ prefix.
    @gha.FieldHint { createOnly = true }
    name: String

    /// Secret value (plaintext). Encrypted by the plugin before sending to GitHub.
    /// Write-only: excluded from Read comparisons.
    @gha.FieldHint { writeOnly = true }
    value: String

    /// SHA-256 hash of the plaintext value. Computed by the plugin on create/update.
    /// Used for drift detection since the API never returns secret values.
    @gha.FieldHint {}
    valueHash: String?
}
