amends "pkl:Project"

dependencies {
  // Reference local plugin schema during development
  // IMPORTANT: The alias must match the package name from the schema's PklProject
  ["gha"] = import("../schema/pkl/PklProject")

  // Formae schema - fetched from public registry
  ["formae"] {
    uri = "package://hub.platform.engineering/plugins/pkl/schema/pkl/formae/formae@0.83.0"
  }

  // GitHub Actions workflow types from pkl-pantry
  ["com.github.actions"] {
    uri = "package://pkg.pkl-lang.org/pkl-pantry/com.github.actions@1.3.2"
  }
}
