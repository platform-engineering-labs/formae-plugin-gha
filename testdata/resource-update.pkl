/*
 * Conformance Test: Update Resources (in-place)
 *
 * Changes:
 *   - repo variable value: "initial-value" -> "updated-value"
 *   - env variable value: "env-initial" -> "env-updated"
 */
amends "@formae/forma.pkl"
import "@formae/formae.pkl"
import "@gha/repo/repovariable.pkl" as repovar
import "@gha/env/environment.pkl"
import "@gha/env/envvariable.pkl" as envvar
import "@gha/gha.pkl"

local stackName = "plugin-sdk-test-stack"
local testRunID = read("env:FORMAE_TEST_RUN_ID")

local testEnv = new environment.Environment {
    label = "test-env"
    name = "formae-test-\(testRunID)"
}

forma {
  new formae.Stack {
    label = stackName
    description = "GHA plugin conformance test stack"
  }

  new formae.Target {
    label = "gha-target"
    namespace = "GHA"
    config = new gha.Config {
      owner = read("env:GHA_TEST_OWNER")
      repo = read("env:GHA_TEST_REPO")
    }
  }

  new repovar.Variable {
    label = "test-repo-var"
    name = "FORMAE_TEST_VAR_\(testRunID.toUpperCase())"
    value = "updated-value"                // CHANGED
  }

  testEnv

  new envvar.Variable {
    label = "test-env-var"
    environment = testEnv.res.name
    name = "FORMAE_TEST_ENVVAR"
    value = "env-updated"                  // CHANGED
  }
}
